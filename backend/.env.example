APP_NAME="Ecole RDC"
ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg2://ecole:ecole_password@localhost:5432/ecole_rdc
JWT_SECRET_KEY=change-this-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720
FRONTEND_URL=http://localhost:5173
GENERATED_DIR=generated

MINISTRY_VERIFICATION_BASE_URL=http://localhost:5173

# Email optionnel : sans SMTP, les emails parents sont simulés et journalisés dans les notifications.
